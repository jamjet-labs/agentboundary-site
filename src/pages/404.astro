---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Not found — AgentBoundary" description="That page does not exist.">
  <main style="min-height: 60vh; display: grid; place-items: center; padding: 24px;">
    <div style="text-align: center; max-width: 480px;">
      <p style="font-family: var(--font-mono); color: var(--accent); margin: 0 0 12px;">404</p>
      <h1 style="font-size: 2.4rem; margin: 0 0 16px;">Not in this spec.</h1>
      <p style="color: var(--fg-muted);">
        Try the <a href="/">landing</a>, the <a href="/spec/v0.1">v0.1 spec</a>,
        the <a href="/threat-model">threat model</a>, or the
        <a href="/owasp-mapping">OWASP mapping</a>.
      </p>
    </div>
  </main>
</BaseLayout>
